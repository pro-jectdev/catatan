<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Finance Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        html { scroll-behavior: smooth; }
        body { font-family: 'Inter', sans-serif; background: radial-gradient(circle at top left, #dbeafe 0%, transparent 30%), radial-gradient(circle at bottom right, #ede9fe 0%, transparent 30%), #f8fafc; }
        .glass { background: rgba(255,255,255,0.75); backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px); }
    </style>
</head>
<body class="min-h-screen p-4 md:p-8 text-slate-800">
    <div class="max-w-7xl mx-auto">
        <div class="flex flex-col lg:flex-row gap-6 mb-8">
            <div class="glass rounded-[2rem] p-8 shadow-xl border border-white/50 flex-1">
                <p class="uppercase tracking-[0.3em] text-xs font-bold text-blue-600 mb-4">FINANCE TRACKER</p>
                <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900">Dashboard <span class="text-blue-600">Keuangan</span></h1>
                <p class="mt-5 text-slate-500 max-w-2xl">Monitoring pengeluaran real-time.</p>
            </div>
            <div class="bg-gradient-to-br from-blue-600 to-indigo-600 rounded-[2rem] p-8 text-white shadow-2xl min-w-[320px] flex flex-col justify-center">
                <p class="uppercase tracking-[0.3em] text-xs font-bold opacity-80 mb-4">Total Pengeluaran</p>
                <h2 id="totalPengeluaran" class="text-3xl sm:text-4xl md:text-5xl font-extrabold break-all leading-tight">Rp 0</h2>
            </div>
        </div>

        <div class="mb-8">
            <div class="glass rounded-3xl p-5 md:p-6 shadow border border-white/50">
                <p class="text-slate-400 text-sm mb-2">Jumlah Transaksi Tercatat</p>
                <h3 id="jumlahTransaksi" class="text-3xl md:text-4xl font-bold text-slate-900">0</h3>
            </div>
        </div>

        <div class="glass rounded-[2rem] shadow-xl border border-white/50 overflow-hidden">
            <div class="p-6 border-b sticky top-0 bg-white/70 backdrop-blur-md z-10 flex items-center justify-between">
                <h2 class="text-xl font-bold">Timeline Transaksi</h2>
                <button onclick="muatData()" class="text-xs bg-blue-500 text-white px-3 py-1 rounded-lg hover:bg-blue-600 transition">Refresh</button>
            </div>
            <div id="timeline" class="p-4 md:p-6 space-y-3 max-h-[520px] overflow-y-auto"></div>
        </div>
    </div>

    <script>
        // MASUKKAN URL WEB APP ANDA DI SINI (DAPAT DARI MENU DEPLOY > NEW DEPLOYMENT)
        const WEB_APP_URL = "https://script.google.com/macros/s/AKfycbz-GZfeckMrccMu9GeQo-b85EiFxBiJBGlY7hkuAKQ75AC2keL3I83wIltyBgm435sgwg/exec";

        const totalEl = document.getElementById('totalPengeluaran');
        const jumlahEl = document.getElementById('jumlahTransaksi');
        const timelineEl = document.getElementById('timeline');

        function formatRupiah(num) {
            return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(num);
        }

        async function muatData() {
            try {
                timelineEl.innerHTML = `<div class="text-center py-10 text-slate-400">Memuat data...</div>`;
                const res = await fetch(`${WEB_APP_URL}?action=read`).then(r => r.json());
                
                let total = res.reduce((acc, e) => acc + (Number(e.jumlah) || 0), 0);
                totalEl.textContent = formatRupiah(total);
                jumlahEl.textContent = res.length;

                renderTimeline([...res].reverse());
            } catch (err) {
                timelineEl.innerHTML = `<div class="text-center py-10 text-red-500">Gagal memuat data. Periksa URL Web App dan izin akses (Anyone).</div>`;
            }
        }

        function renderTimeline(data) {
            timelineEl.innerHTML = data.length ? '' : `<div class="text-center text-slate-400 py-10">Belum ada transaksi</div>`;
            if (!data.length) return;

            const avg = data.reduce((acc, d) => acc + (Number(d.jumlah) || 0), 0) / data.length;

            data.forEach(d => {
                const jumlah = Number(d.jumlah) || 0;
                const isBig = jumlah >= 100000 || jumlah >= (1.5 * avg);
                const badge = isBig ? `<span class="text-[10px] bg-red-100 text-red-500 px-2 py-1 rounded-full ml-2">Besar</span>` : '';

                timelineEl.innerHTML += `
                <div class="bg-white/70 border border-slate-100 rounded-2xl p-4 shadow-sm hover:shadow-md transition">
                    <div class="flex items-start justify-between gap-3">
                        <div class="flex-1">
                            <p class="font-semibold text-slate-800">${d.deskripsi} ${badge}</p>
                            <p class="text-xs text-slate-400 mt-1">${d.tanggal}</p>
                        </div>
                        <div class="text-right font-bold ${isBig ? 'text-red-500' : 'text-blue-600'} flex flex-col items-end gap-2">
                            <span>${formatRupiah(jumlah)}</span>
                            <button onclick="hapusTransaksi('${d.id}')" class="text-[10px] text-slate-400 hover:text-red-500 transition">🗑 Hapus</button>
                        </div>
                    </div>
                </div>`;
            });
        }

        async function hapusTransaksi(id) {
            if (!confirm("Yakin mau hapus transaksi ini?")) return;
            try {
                await fetch(`${WEB_APP_URL}?action=delete&id=${id}`);
                muatData();
            } catch (err) {
                alert("Gagal menghapus");
            }
        }

        window.onload = muatData;
    </script>
</body>
</html>
